<!-- LISTING TYPES -->
<section class="listing-types">
    <div class="listing-inner">
        <div class="section-label" style="color:var(--blue)">Three Listing Types</div>
        <h2 class="section-title" style="color:var(--ink)">Choose what fits you best</h2>
        <p style="color:var(--muted);font-size:1rem;max-width:500px;">Whether you want global opportunities, community finds, or campus-exclusive roles — we have it all.</p>
        <div class="listing-grid">
            <a href="/home?type=api" class="listing-card">
                <div class="lc-icon api"><i class="fas fa-globe" style="color:var(--blue)"></i></div>
                <div class="lc-title">Global Job Feed</div>
                <div class="lc-desc">Thousands of live internships and jobs from top companies worldwide, updated daily via our API integration.</div>
                <span class="lc-tag api">API Powered</span>
            </a>
            <a href="/home?type=added" class="listing-card">
                <div class="lc-icon added"><i class="fas fa-plus-circle" style="color:#065f46"></i></div>
                <div class="lc-title">Community Listings</div>
                <div class="lc-desc">Listings added by AMU students and alumni. Share jobs you discover and help your peers find great opportunities.</div>
                <span class="lc-tag added">Community</span>
            </a>
            <a href="/home?type=zhcet" class="listing-card featured">
                <div class="lc-icon zhcet"><i class="fas fa-graduation-cap" style="color:#e65100"></i></div>
                <div class="lc-title">ZHCET Listings</div>
                <div class="lc-desc">Exclusive internships and project traineeships posted by ZHCET faculty. Apply directly with your CV uploaded.</div>
                <span class="lc-tag zhcet">🎓 ZHCET Exclusive</span>
            </a>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
    <div class="how-inner">
        <div class="section-label" style="color:var(--blue)">How It Works</div>
        <h2 class="section-title" style="color:var(--ink)">Get started in minutes</h2>
        <div class="steps">
            <div class="step-item">
                <div class="step-num">1</div>
                <div class="step-title">Create Account</div>
                <div class="step-desc">Sign up with your AMU email, course, and branch details.</div>
            </div>
            <div class="step-item">
                <div class="step-num">2</div>
                <div class="step-title">Browse Jobs</div>
                <div class="step-desc">Filter by API, community, or ZHCET listings.</div>
            </div>
            <div class="step-item">
                <div class="step-num">3</div>
                <div class="step-title">Apply</div>
                <div class="step-desc">Apply directly or upload your CV for ZHCET roles.</div>
            </div>
            <div class="step-item">
                <div class="step-num">4</div>
                <div class="step-title">Get Hired</div>
                <div class="step-desc">Track your applications and land your dream role.</div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <h2>Ready to find your next opportunity?</h2>
    <p>Join hundreds of ZHCET students already using CareerPortal.</p>
    <div class="cta-buttons">
        <a href="/signup" class="btn-cta-white">Create Free Account</a>
        <a href="/home" class="btn-cta-outline">Browse Listings</a>
    </div>
</section>

<footer>
    <p>© 2025 CareerPortal · ZHCET, Aligarh Muslim University &nbsp;|&nbsp; <a href="/admin/login">Admin Login</a></p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
