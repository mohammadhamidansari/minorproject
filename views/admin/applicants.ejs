<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= listing.title %> Applicants | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family:'DM Sans',sans-serif; background:#f5f6fa; }
        .admin-nav { background:#0a0a12; padding:14px 32px; display:flex; align-items:center; justify-content:space-between; }
        .admin-nav-brand { font-family:'Syne',sans-serif; font-weight:800; color:#fff; font-size:1.2rem; }
        .page-header { background:linear-gradient(135deg,#e65100,#bf360c); color:#fff; padding:40px 32px; }
        .page-header h1 { font-family:'Syne',sans-serif; font-weight:800; font-size:1.8rem; }
        .card-box { background:#fff; border-radius:16px; padding:28px; box-shadow:0 4px 20px rgba(0,0,0,.06); }
        .app-table { width:100%; border-collapse:collapse; }
        .app-table th { background:#f8f9fa; padding:12px 16px; text-align:left; font-size:.78rem; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; border-bottom:1.5px solid #e5e7eb; }
        .app-table td { padding:14px 16px; border-bottom:1px solid #f3f4f6; vertical-align:middle; }
        .app-table tr:hover td { background:#fafafa; }
        .status-badge { padding:3px 10px; border-radius:100px; font-size:.75rem; font-weight:600; }
        .status-pending { background:#fef3c7; color:#92400e; }
        .status-reviewed { background:#dbeafe; color:#1e40af; }
        .status-accepted { background:#d1fae5; color:#065f46; }
        .status-rejected { background:#fee2e2; color:#991b1b; }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <div class="admin-nav-brand">CareerPortal <span style="background:#ef4444;color:#fff;padding:2px 8px;border-radius:6px;font-size:.75rem;">ADMIN</span></div>
        <a href="/admin/dashboard" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:.85rem;"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
    </nav>

    <div class="page-header">
        <div class="container-fluid px-4">
            <div style="font-size:.8rem;opacity:.6;margin-bottom:6px;text-transform:uppercase;letter-spacing:.08em;">ZHCET Listing</div>
            <h1><%= listing.title %></h1>
            <p style="opacity:.8;margin:0;"><%= listing.department %> · <%= applications.length %> applicant(s)</p>
        </div>
    </div>

    <div class="container-fluid px-4 py-4">
        <div class="card-box">
            <% if (applications && applications.length > 0) { %>
            <div class="table-responsive">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student</th>
                            <th>Year & Branch</th>
                            <th>Applied On</th>
                            <th>Cover Note</th>
                            <th>CV</th>
                            <th>Status</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% applications.forEach((app, i) => { %>
                        <tr>
                            <td style="color:#9ca3af;font-size:.8rem;"><%= i + 1 %></td>
                            <td>
                                <div style="font-weight:700;"><%= app.user ? app.user.name : 'N/A' %></div>
                                <div style="color:#6b7280;font-size:.78rem;"><%= app.user ? app.user.email : '' %></div>
                            </td>
                            <td style="font-size:.85rem;">
                                <%= app.user ? app.user.year + ' · ' + app.user.branch : '—' %>
                            </td>
                            <td style="font-size:.8rem;color:#6b7280;">
                                <%= new Date(app.appliedAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
                            </td>
                            <td style="font-size:.82rem;max-width:200px;">
                                <% if(app.coverNote) { %>
                                    <span title="<%= app.coverNote %>" style="cursor:help;color:#374151;">
                                        <%= app.coverNote.substring(0,60) %><%= app.coverNote.length > 60 ? '...' : '' %>
                                    </span>
                                <% } else { %>
                                    <span class="text-muted">—</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/admin/cv/<%= app._id %>" target="_blank" class="btn btn-sm btn-outline-danger py-1 px-2">
                                    <i class="fas fa-file-pdf me-1"></i>Download
                                </a>
                            </td>
                            <td>
                                <span class="status-badge status-<%= app.status || 'pending' %>">
                                    <%= (app.status || 'pending').charAt(0).toUpperCase() + (app.status || 'pending').slice(1) %>
                                </span>
                            </td>
                            <td>
                                <form action="/admin/applications/<%= app._id %>/status" method="POST" style="display:flex;gap:4px;">
                                    <select name="status" class="form-select form-select-sm" style="font-size:.75rem;border-radius:6px;min-width:100px;">
                                        <option value="pending" <%= app.status==='pending'?'selected':'' %>>Pending</option>
                                        <option value="reviewed" <%= app.status==='reviewed'?'selected':'' %>>Reviewed</option>
                                        <option value="accepted" <%= app.status==='accepted'?'selected':'' %>>Accept</option>
                                        <option value="rejected" <%= app.status==='rejected'?'selected':'' %>>Reject</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-dark px-2">✓</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="text-center py-5">
                <div style="font-size:3rem;opacity:.3;">📋</div>
                <h5 class="mt-3 text-muted">No applications yet</h5>
                <p class="text-muted small">Students haven't applied to this listing yet.</p>
            </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
