<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | CareerPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background: linear-gradient(135deg, #0a0a12 0%, #1a1a2e 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .admin-card {
            background: #fff; border-radius: 20px;
            padding: 48px 40px; width: 100%; max-width: 420px;
            box-shadow: 0 24px 64px rgba(0,0,0,.4);
        }
        .admin-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: #fee2e2; color: #dc2626; padding: 4px 12px;
            border-radius: 100px; font-size: .75rem; font-weight: 600;
            margin-bottom: 20px;
        }
        .admin-card h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.8rem; margin-bottom: 6px; }
        .admin-card p.sub { color: #6b7280; margin-bottom: 32px; }
        .form-label { font-weight: 600; font-size: .85rem; color: #374151; }
        .form-control { border-radius: 10px; padding: 10px 14px; border: 1.5px solid #e5e7eb; }
        .form-control:focus { border-color: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,.1); }
        .btn-admin {
            background: #0a0a12; color: #fff; border: none;
            padding: 12px; border-radius: 10px; font-weight: 600;
            width: 100%; transition: all .25s;
        }
        .btn-admin:hover { background: #dc2626; }
    </style>
</head>
<body>
<div class="admin-card">
    <span class="admin-badge"><i class="fas fa-shield-alt"></i> Admin Access</span>
    <h2>Admin Login</h2>
    <p class="sub">ZHCET CareerPortal Administration</p>

    <% if (error && error.length > 0) { %>
    <div class="alert alert-danger mb-3 rounded-3"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
        <div class="mb-3">
            <label class="form-label">Admin Email</label>
            <input type="email" name="email" class="form-control" placeholder="admin@zhcet.ac.in" required>
        </div>
        <div class="mb-4">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Enter admin password" required>
        </div>
        <button type="submit" class="btn-admin">
            <i class="fas fa-sign-in-alt me-2"></i>Login as Admin
        </button>
    </form>
    <div class="text-center mt-4">
        <a href="/" class="text-muted small"><i class="fas fa-arrow-left me-1"></i>Back to Home</a>
    </div>
    <div class="text-center mt-2">
        <a href="/admin/signup" class="text-muted small">Create Admin Account</a>
    </div>
</div>
</body>
</html>
