<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | CareerPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family:'DM Sans',sans-serif; background:#f5f6fa; }
        .admin-nav { background:#0a0a12; padding:14px 32px; display:flex; align-items:center; justify-content:space-between; }
        .admin-nav-brand { font-family:'Syne',sans-serif; font-weight:800; color:#fff; font-size:1.2rem; }
        .admin-nav-brand span { color:#ef4444; }
        .admin-header { background:linear-gradient(135deg,#0a0a12,#1a1a2e); color:#fff; padding:40px 32px; }
        .admin-header h1 { font-family:'Syne',sans-serif; font-weight:800; font-size:1.8rem; }
        .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:32px; }
        .stat-card { background:#fff; border-radius:14px; padding:24px; box-shadow:0 2px 12px rgba(0,0,0,.06); }
        .stat-card .s-num { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; }
        .stat-card .s-lbl { color:#6b7280; font-size:.85rem; margin-top:4px; }
        .stat-card.blue .s-num { color:#0052ff; }
        .stat-card.orange .s-num { color:#e65100; }
        .stat-card.green .s-num { color:#059669; }
        .stat-card.red .s-num { color:#dc2626; }

        .section-card { background:#fff; border-radius:16px; padding:28px; box-shadow:0 2px 12px rgba(0,0,0,.06); margin-bottom:24px; }
        .section-card h3 { font-family:'Syne',sans-serif; font-weight:700; font-size:1.2rem; margin-bottom:20px; }

        /* Listing management */
        .listing-row { border:1.5px solid #e5e7eb; border-radius:12px; padding:16px 20px; margin-bottom:12px; display:flex; align-items:center; gap:16px; }
        .listing-row:hover { border-color:#e65100; background:#fff8f5; }
        .lr-icon { width:44px; height:44px; background:#fff3e0; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
        .lr-info { flex: 1; }
        .lr-title { font-weight:700; font-size:.95rem; }
        .lr-sub { color:#6b7280; font-size:.8rem; }
        .lr-meta { display:flex; gap:8px; flex-wrap:wrap; margin-top:4px; }
        .lr-badge { padding:2px 8px; border-radius:100px; font-size:.7rem; font-weight:600; background:#fff3e0; color:#e65100; }

        /* Applicants table */
        .app-table { width:100%; border-collapse:collapse; }
        .app-table th { background:#f8f9fa; padding:10px 14px; text-align:left; font-size:.8rem; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; border-bottom:1.5px solid #e5e7eb; }
        .app-table td { padding:12px 14px; border-bottom:1px solid #f3f4f6; vertical-align:middle; }
        .app-table tr:hover td { background:#fafafa; }
        .status-badge { padding:3px 10px; border-radius:100px; font-size:.75rem; font-weight:600; }
        .status-pending { background:#fef3c7; color:#92400e; }
        .status-reviewed { background:#dbeafe; color:#1e40af; }
        .status-accepted { background:#d1fae5; color:#065f46; }
        .status-rejected { background:#fee2e2; color:#991b1b; }

        .btn-add-zhcet { background:#e65100; color:#fff; border:none; padding:10px 20px; border-radius:10px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; text-decoration:none; }
        .btn-add-zhcet:hover { background:#bf360c; color:#fff; }
    </style>
</head>
<body>
    <!-- Admin Navbar -->
    <nav class="admin-nav">
        <div class="admin-nav-brand">Career<span>Portal</span> &nbsp;<span style="background:#ef4444;color:#fff;padding:2px 8px;border-radius:6px;font-size:.75rem;">ADMIN</span></div>
        <div style="display:flex;gap:12px;align-items:center;">
            <span style="color:rgba(255,255,255,.6);font-size:.85rem;">Welcome, <%= admin.name %></span>
            <a href="/admin/logout" style="background:rgba(255,255,255,.1);color:#fff;padding:6px 14px;border-radius:8px;text-decoration:none;font-size:.85rem;">Logout</a>
        </div>
    </nav>

    <!-- Admin Header -->
    <div class="admin-header">
        <div class="container-fluid px-4">
            <p style="color:rgba(255,255,255,.5);font-size:.8rem;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;">Dashboard</p>
            <h1>ZHCET Administration Panel</h1>
            <p style="opacity:.7;margin-top:4px;">Manage ZHCET listings and track applications</p>
        </div>
    </div>

    <div class="container-fluid px-4 py-4">

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card blue">
                <div class="s-num"><%= stats.totalListings %></div>
                <div class="s-lbl">Total ZHCET Listings</div>
            </div>
            <div class="stat-card orange">
                <div class="s-num"><%= stats.totalApplications %></div>
                <div class="s-lbl">Total Applications</div>
            </div>
            <div class="stat-card green">
                <div class="s-num"><%= stats.accepted %></div>
                <div class="s-lbl">Accepted</div>
            </div>
            <div class="stat-card red">
                <div class="s-num"><%= stats.pending %></div>
                <div class="s-lbl">Pending Review</div>
            </div>
        </div>

        <div class="row g-4">
            <!-- ZHCET Listings Management -->
            <div class="col-lg-5">
                <div class="section-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0">ZHCET Listings</h3>
                        <a href="/admin/zhcet/new" class="btn-add-zhcet">
                            <i class="fas fa-plus"></i>Add Listing
                        </a>
                    </div>
                    <% if (zhcetListings && zhcetListings.length > 0) { %>
                        <% for(let listing of zhcetListings) { %>
                        <div class="listing-row">
                            <div class="lr-icon">🎓</div>
                            <div class="lr-info">
                                <div class="lr-title"><%= listing.title %></div>
                                <div class="lr-sub"><%= listing.department %></div>
                                <div class="lr-meta">
                                    <span class="lr-badge"><%= listing.applications ? listing.applications.length : 0 %> applicants</span>
                                    <% if(listing.deadline) { %><span class="lr-badge" style="background:#fee2e2;color:#dc2626;">Due: <%= new Date(listing.deadline).toLocaleDateString('en-IN') %></span><% } %>
                                </div>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:6px;">
                                <a href="/admin/zhcet/<%= listing._id %>/applicants" class="btn btn-sm btn-outline-warning">View</a>
                                <a href="/admin/zhcet/<%= listing._id %>/delete" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this listing?')">Delete</a>
                            </div>
                        </div>
                        <% } %>
                    <% } else { %>
                    <div class="text-center py-5">
                        <div style="font-size:2.5rem;opacity:.4;">🎓</div>
                        <p class="text-muted mt-2">No ZHCET listings yet.</p>
                        <a href="/admin/zhcet/new" class="btn-add-zhcet mt-2 d-inline-flex">Create First Listing</a>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- All Applicants -->
            <div class="col-lg-7">
                <div class="section-card">
                    <h3>All ZHCET Applicants</h3>
                    <% if (applications && applications.length > 0) { %>
                    <div class="table-responsive">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Listing</th>
                                    <th>Applied</th>
                                    <th>CV</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for(let app of applications) { %>
                                <tr>
                                    <td>
                                        <div style="font-weight:600;font-size:.9rem;"><%= app.user ? app.user.name : 'Unknown' %></div>
                                        <div style="color:#6b7280;font-size:.78rem;"><%= app.user ? app.user.email : '' %></div>
                                        <div style="color:#9ca3af;font-size:.75rem;"><%= app.user ? app.user.year + ' · ' + app.user.branch : '' %></div>
                                    </td>
                                    <td style="font-size:.85rem;"><%= app.listing ? app.listing.title : 'Deleted' %></td>
                                    <td style="font-size:.8rem;color:#6b7280;"><%= new Date(app.appliedAt).toLocaleDateString('en-IN') %></td>
                                    <td>
                                        <% if(app.cvPath) { %>
                                        <a href="/admin/cv/<%= app._id %>" target="_blank" class="btn btn-sm btn-outline-danger py-0 px-2">
                                            <i class="fas fa-file-pdf me-1"></i>CV
                                        </a>
                                        <% } else { %>
                                        <span class="text-muted small">—</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="status-badge status-<%= app.status || 'pending' %>">
                                            <%= (app.status || 'pending').charAt(0).toUpperCase() + (app.status || 'pending').slice(1) %>
                                        </span>
                                    </td>
                                    <td>
                                        <form action="/admin/applications/<%= app._id %>/status" method="POST" style="display:flex;gap:4px;">
                                            <select name="status" class="form-select form-select-sm" style="font-size:.75rem;border-radius:6px;">
                                                <option value="pending" <%= app.status==='pending'?'selected':'' %>>Pending</option>
                                                <option value="reviewed" <%= app.status==='reviewed'?'selected':'' %>>Reviewed</option>
                                                <option value="accepted" <%= app.status==='accepted'?'selected':'' %>>Accept</option>
                                                <option value="rejected" <%= app.status==='rejected'?'selected':'' %>>Reject</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-dark" style="border-radius:6px;">✓</button>
                                        </form>
                                    </td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <div style="font-size:2.5rem;opacity:.4;">📋</div>
                        <p class="text-muted mt-2">No applications received yet.</p>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
