<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New ZHCET Listing | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body { font-family:'DM Sans',sans-serif; background:#f5f6fa; }
        .admin-nav { background:#0a0a12; padding:14px 32px; display:flex; align-items:center; justify-content:space-between; }
        .admin-nav-brand { font-family:'Syne',sans-serif; font-weight:800; color:#fff; font-size:1.2rem; }
        .form-card { background:#fff; border-radius:16px; padding:40px; box-shadow:0 4px 20px rgba(0,0,0,.07); max-width:700px; margin:40px auto; }
        .form-card h2 { font-family:'Syne',sans-serif; font-weight:800; margin-bottom:8px; }
        .form-label { font-weight:600; font-size:.85rem; color:#374151; }
        .form-control, .form-select { border-radius:10px; padding:10px 14px; border:1.5px solid #e5e7eb; }
        .form-control:focus, .form-select:focus { border-color:#e65100; box-shadow:0 0 0 3px rgba(230,81,0,.1); }
        .btn-submit { background:#e65100; color:#fff; border:none; padding:12px 32px; border-radius:10px; font-weight:600; transition:all .2s; }
        .btn-submit:hover { background:#bf360c; color:#fff; }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <div class="admin-nav-brand" style="color:#fff;">CareerPortal <span style="background:#ef4444;color:#fff;padding:2px 8px;border-radius:6px;font-size:.75rem;">ADMIN</span></div>
        <a href="/admin/dashboard" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:.85rem;"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
    </nav>

    <div class="container py-4">
        <div class="form-card">
            <h2>New ZHCET Listing</h2>
            <p class="text-muted mb-4">Create an exclusive internship/project listing for ZHCET students.</p>

            <% if (error && error.length > 0) { %>
            <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/admin/zhcet/new" method="POST">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Position Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" placeholder="e.g. Project Trainee – AI/ML" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Department <span class="text-danger">*</span></label>
                        <input type="text" name="department" class="form-control" placeholder="e.g. Computer Engineering" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Seats Available</label>
                        <input type="number" name="seats" class="form-control" placeholder="e.g. 5" min="1">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Duration</label>
                        <input type="text" name="duration" class="form-control" placeholder="e.g. 2 months, 6 weeks">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Stipend / Compensation</label>
                        <input type="text" name="stipend" class="form-control" placeholder="e.g. ₹5000/month or Unpaid">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Application Deadline</label>
                        <input type="date" name="deadline" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Eligibility (Year)</label>
                        <select name="eligibility" class="form-select">
                            <option value="">Any Year</option>
                            <option value="2nd Year">2nd Year</option>
                            <option value="3rd Year">3rd Year</option>
                            <option value="4th Year">4th Year</option>
                            <option value="3rd or 4th Year">3rd or 4th Year</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Job Description <span class="text-danger">*</span></label>
                        <textarea name="description" class="form-control" rows="5" placeholder="Describe the role, responsibilities, and what the intern will work on..." required></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Requirements / Skills</label>
                        <textarea name="requirements" class="form-control" rows="3" placeholder="e.g. Python, ML basics, 7+ CGPA..."></textarea>
                    </div>
                    <div class="col-12 pt-2">
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-plus me-2"></i>Create ZHCET Listing
                        </button>
                        <a href="/admin/dashboard" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
