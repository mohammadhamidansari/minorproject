<!-- Flash Messages -->
<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
<div style="position:fixed;top:84px;right:20px;z-index:9999;max-width:340px;">
    <div class="alert alert-success shadow-sm d-flex align-items-center gap-2 py-2 px-3" style="border-radius:10px;border:none;background:#d1fae5;color:#065f46;">
        <i class="fas fa-check-circle"></i> <%= success %>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" style="font-size:.7rem;"></button>
    </div>
</div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
<div style="position:fixed;top:84px;right:20px;z-index:9999;max-width:340px;">
    <div class="alert alert-danger shadow-sm d-flex align-items-center gap-2 py-2 px-3" style="border-radius:10px;border:none;">
        <i class="fas fa-exclamation-circle"></i> <%= error %>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" style="font-size:.7rem;"></button>
    </div>
</div>
<% } %>
